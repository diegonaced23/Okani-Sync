# ─────────────────────────────────────────────────────────────────────────────
# Okany Sync — Variables de entorno
# Copiar este archivo a .env.local y completar los valores.
# NUNCA subir .env.local al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com → Tu aplicación → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...       # Dashboard → Webhooks → Signing Secret

# Rutas de redirección Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard

# JWT Issuer para Convex (Dashboard → JWT Templates → Convex)
CLERK_JWT_ISSUER_DOMAIN=https://<tu-clerk-domain>.clerk.accounts.dev

# ── Convex ───────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.convex.dev → Tu proyecto → Settings
NEXT_PUBLIC_CONVEX_URL=https://<tu-proyecto>.convex.cloud
CONVEX_DEPLOY_KEY=prod:...           # Solo necesario para deploy

# ── Resend (emails transaccionales) ─────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
# En desarrollo usar el remitente de pruebas. Cuando tengas dominio, cambiar.
RESEND_FROM_EMAIL=Okany Sync <onboarding@resend.dev>

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:it.boccol@gmail.com

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry (opcional, solo en producción) ─────────────────────────────────────
# https://sentry.io → Crear proyecto Next.js → obtener DSN
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=tu-org-slug
SENTRY_PROJECT=okany-sync
SENTRY_AUTH_TOKEN=sntrys_...
